# ── Database (Neon) ──────────────────────────────────────────────────────────
# Both URLs point to the same Neon project.
# DATABASE_URL  → pooled endpoint (for runtime queries).
# DIRECT_URL    → direct endpoint  (for prisma migrate).
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.neon.tech:5432/neondb?sslmode=require
DIRECT_URL=postgresql://user:pass@ep-xxx.neon.tech:5432/neondb?sslmode=require

# ── Auth.js ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32  OR  npx auth secret
AUTH_SECRET=replace-with-generated-secret
# Production URL — used for OAuth callbacks and invitation email links.
# Must be the exact origin (no trailing slash).
AUTH_URL=https://readiness.getspanforge.com

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=SpanForge <noreply@getspanforge.com>
